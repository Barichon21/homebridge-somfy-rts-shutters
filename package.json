{
  "displayName": "Homebridge Somfy RTS Shutters (RFXCOM)",
  "name": "homebridge-somfy-rts-shutters",
  "version": "0.1.0",
  "description": "Homebridge plugin exposing Somfy RTS roller shutters (via an RFXtrx433E dongle) as native HomeKit WindowCovering accessories. Converts the target position (%) into an up/down RTS command duration to simulate absolute positioning.",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": "^20 || ^22 || ^24",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && npm link && nodemon",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "rfxcom",
    "rfxtrx",
    "somfy",
    "rts",
    "shutters",
    "volet-roulant",
    "windowcovering"
  ],
  "dependencies": {
    "rfxcom": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "homebridge": "^1.7.0",
    "nodemon": "^3.0.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  },
  "author": {
    "name": "barichon21000",
    "url": "https://github.com/Barichon21"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Barichon21/homebridge-somfy-rts-shutters.git"
  },
  "bugs": {
    "url": "https://github.com/Barichon21/homebridge-somfy-rts-shutters/issues"
  },
  "homepage": "https://github.com/Barichon21/homebridge-somfy-rts-shutters#readme",
  "files": [
    "dist",
    "config.schema.json",
    "scripts"
  ]
}
